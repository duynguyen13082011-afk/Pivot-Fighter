					for(int i=1; i<fp.length; i++) path.lineTo(p3[fp[i]][0], p3[fp[i]][1]); path.close(); c.drawPath(path, sp);
				}
			}
			float[] r2c = engine3D.rotate3D(selectedObj.pts[0], selectedObj.pts[1], selectedObj.pos3DZ, camRotX, camRotY, 0);
			float scx = r2c[0]*camZoom; float scy = r2c[1]*camZoom; float alen = 180;
