	boolean isOrbitInit = false;
	float localOffX, localOffY, localOffZ;
    float localRotX, localRotY, localRotZ;

    public void sync3DOrbit() {
        for (SObject child : children) {
            if (child.attachPointIdx == -1 && child.type >= 10) {
                if (!child.isOrbitInit) {
                    float vx = child.pts[0] - this.pts[0];
                    float vy = child.pts[1] - this.pts[1]; 
                    float vz = child.pos3DZ - this.pos3DZ;
                    
                    float cx = (float)Math.cos(this.rot3DX), sx = (float)Math.sin(this.rot3DX);
                    float cy = (float)Math.cos(this.rot3DY), sy = (float)Math.sin(this.rot3DY);
                    float cz = (float)Math.cos(this.rot3DZ), sz = (float)Math.sin(this.rot3DZ);
                    
                    // Giải mã quỹ đạo nghịch đảo
                    float x1 = vx * cz + vy * sz; float y1 = -vx * sz + vy * cz; float z1 = vz;
                    float x2 = x1 * cy - z1 * sy; float y2 = y1; float z2 = x1 * sy + z1 * cy;
                    float x3 = x2; float y3 = y2 * cx + z2 * sx; float z3 = -y2 * sx + z2 * cx;
                    
                    child.localOffX = x3; 
                    child.localOffY = y3; 
                    child.localOffZ = z3;
                    
                    // Lưu lại góc lệch gốc của khối con so với khối mẹ
                    child.localRotX = child.rot3DX - this.rot3DX;
                    child.localRotY = child.rot3DY - this.rot3DY;
                    child.localRotZ = child.rot3DZ - this.rot3DZ;
                    child.isOrbitInit = true;
                }

                // 1. TÍNH TOÁN VỊ TRÍ (QUỸ ĐẠO QUAY CỦA VỆ TINH)
                float cx = (float)Math.cos(this.rot3DX), sx = (float)Math.sin(this.rot3DX);
                float cy = (float)Math.cos(this.rot3DY), sy = (float)Math.sin(this.rot3DY);
                float cz = (float)Math.cos(this.rot3DZ), sz = (float)Math.sin(this.rot3DZ);
                
                float px1 = child.localOffX; float py1 = child.localOffY * cx - child.localOffZ * sx; float pz1 = child.localOffY * sx + child.localOffZ * cx;
                float px2 = px1 * cy + pz1 * sy; float py2 = py1; float pz2 = -px1 * sy + pz1 * cy;
                float px3 = px2 * cz - py2 * sz; float py3 = px2 * sz + py2 * cz; float pz3 = pz2;
                
                child.pts[0] = this.pts[0] + px3;
                child.pts[1] = this.pts[1] + py3; 
                child.pos3DZ = this.pos3DZ + pz3;
                
                // 2. KẾT HỢP GÓC XOAY BẰNG MA TRẬN 3x3 (CHỐNG HOÁN ĐỔI TRỤC)
                // Lập ma trận xoay của Vật Mẹ (Parent Matrix)
                float[] pM = {
                    cy*cz, sx*sy*cz - cx*sz, cx*sy*cz + sx*sz,
                    cy*sz, sx*sy*sz + cx*cz, cx*sy*sz - sx*cz,
                    -sy,   sx*cy,            cx*cy
                };
                
                // Lập ma trận xoay của Vật Con (Local Matrix)
                float lcx = (float)Math.cos(child.localRotX), lsx = (float)Math.sin(child.localRotX);
                float lcy = (float)Math.cos(child.localRotY), lsy = (float)Math.sin(child.localRotY);
                float lcz = (float)Math.cos(child.localRotZ), lsz = (float)Math.sin(child.localRotZ);
                float[] lM = {
                    lcy*lcz, lsx*lsy*lcz - lcx*lsz, lcx*lsy*lcz + lsx*lsz,
                    lcy*lsz, lsx*lsy*lsz + lcx*lcz, lcx*lsy*lsz - lsx*lcz,
                    -lsy,    lsx*lcy,               lcx*lcy
                };
                
                // Nhân 2 ma trận với nhau (Combined Matrix = Parent * Local)
                float[] cM = new float[9];
                for(int r = 0; r < 3; r++) {
                    for(int c = 0; c < 3; c++) {
                        cM[r*3 + c] = pM[r*3 + 0]*lM[0*3 + c] + pM[r*3 + 1]*lM[1*3 + c] + pM[r*3 + 2]*lM[2*3 + c];
                    }
                }
                
                // Dịch ngược Ma trận ra góc Euler (X, Y, Z) cuối cùng
                child.rot3DX = (float)Math.atan2(cM[7], cM[8]);
                child.rot3DY = (float)Math.asin(Math.max(-1.0, Math.min(1.0, -cM[6])));
                child.rot3DZ = (float)Math.atan2(cM[3], cM[0]);
                
                // Cập nhật cho các mảnh nối tiếp bên trong
                child.sync3DOrbit();
            }
        }
    }

	public void rotateEntireObject(float pivotX, float pivotY, float newPivotX, float newPivotY, double angle) { 
        float cos = (float) Math.cos(angle); 
        float sin = (float) Math.sin(angle); 
        for (int i = 0; i < pts.length / 2; i++) { 
            float vX = pts[i * 2] - pivotX; 
            float vY = pts[i * 2 + 1] - pivotY; 
            float rotX = vX * cos - vY * sin; 
            float rotY = vX * sin + vY * cos; 
            pts[i * 2] = newPivotX + rotX; 
            pts[i * 2 + 1] = newPivotY + rotY; 
        } 
        if (type >= 10 && type <= 16) { 
            rot3DZ += angle; 
        }
        for (SObject child: children) { 
            child.ensureArrays();
		    child.rotateEntireObject(pivotX, pivotY, newPivotX, newPivotY, angle); 
        } 
    }
