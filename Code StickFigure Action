	public void checkGif() { if (imagePath != null && imagePath.toLowerCase().endsWith(".gif")) try { gifMovie = android.graphics.Movie.decodeFile(imagePath); } catch (Exception e) {} }
	public void loadSfnData() { if (sfnDataProject.isEmpty()) return; try { cachedSfnFrames = new java.util.ArrayList<>();
org.json.JSONArray ja; if(sfnDataProject.startsWith("{")) ja = new org.json.JSONObject(sfnDataProject).getJSONArray("frames"); else ja = new org.json.JSONArray(sfnDataProject); 
