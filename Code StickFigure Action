	public void linkParents() { for (SObject c: children) { c.parentObj = this; c.linkParents(); } }
	public float[] getAbsolutePos(int index) {
		if (index >= pts.length / 2) return new float[]{0,0};
		float ax = pts[index * 2]; float ay = pts[index * 2 + 1]; SObject curr = this;
		while (curr.parentObj != null) { float attachX = curr.parentObj.pts[curr.attachPointIdx * 2]; float attachY = curr.parentObj.pts[curr.attachPointIdx * 2 + 1]; float rootX = curr.pts[curr.rootIdx * 2]; float rootY = curr.pts[curr.rootIdx * 2 + 1]; ax += (attachX - rootX); ay += (attachY - rootY); curr = curr.parentObj; } return new float[] { ax, ay };
	}
	public float[] getAbsoluteDrawPos(int index, int depth) {
		if (depth > 15) return new float[]{0,0}; ensureArrays(); float rootX = pts[rootIdx * 2]; float rootY = pts[rootIdx * 2 + 1]; float myScale = scale; SObject p = parentObj;
		while(p != null) { myScale *= p.scale; p = p.parentObj; } float rawX = pts[index * 2]; float rawY = pts[index * 2 + 1]; float absX = rootX + (rawX - rootX) * myScale; float absY = rootY + (rawY - rootY) * myScale; SObject curr = this;
		while(curr.parentObj != null) { SObject par = curr.parentObj; float parScale = par.scale; SObject pp = par.parentObj; while(pp != null) { parScale *= pp.scale; pp = pp.parentObj; } float pRootX = par.pts[par.rootIdx * 2]; float pRootY = par.pts[par.rootIdx * 2 + 1]; float pAttX = par.pts[curr.attachPointIdx * 2]; float pAttY = par.pts[curr.attachPointIdx * 2 + 1]; float scaledPAttX = pRootX + (pAttX - pRootX) * parScale; float scaledPAttY = pRootY + (pAttY - pRootY) * parScale; float cRootX = curr.pts[curr.rootIdx * 2]; float cRootY = curr.pts[curr.rootIdx * 2 + 1]; absX += (scaledPAttX - cRootX); absY += (scaledPAttY - cRootY); curr = par; } return new float[]{absX, absY};
	}
	public SObject(int t, float x, float y) {
		uuid = java.util.UUID.randomUUID().toString(); type = t; isFilled = false; fillColor = Color.parseColor("#80000000");
		if (type >= 10 && type <= 16) { pts = new float[]{x, y}; rootIdx = 0; }
		else if (type == 0 || type == 13) { pts = new float[]{x, y-100, x, y-50, x, y+50, x-30, y-20, x-60, y+10, x+30, y-20, x+60, y+10, x-30, y+100, x-30, y+150, x+30, y+100, x+30, y+150}; rootIdx = 2; } 
		else if (type == 1) { pts = new float[] { x, y, x + 150, y }; rootIdx = 0; } 
		else if (type == 2) { pts = new float[] { x, y, x + 100, y + 100 }; rootIdx = 0; } 
		else if (type == 3) { pts = new float[] { x, y, x + 50, y - 100, x + 100, y }; rootIdx = 0; } 
		else if (type == 4) { pts = new float[] { x, y - 60, x, y + 60 }; rootIdx = 1; } 
		else if (type == 5) { pts = new float[] { x - 50, y - 50, x + 50, y - 50, x + 50, y + 50, x - 50, y + 50 }; rootIdx = 0; } 
		else if (type == 6) { pts = new float[] { x, y - 50, x + 50, y + 50, x - 50, y + 50 }; rootIdx = 0; } 
		else if (type >= 7 && type <= 9) { pts = new float[] { x, y, x + 100, y }; rootIdx = 0; }
		limbColors = new int[pts.length / 2]; for (int i = 0; i < limbColors.length; i++) limbColors[i] = Color.BLACK; neonColor = Color.GREEN;
		initParents(); jointTypes = new int[pts.length / 2]; formTypes = new int[pts.length / 2]; dotTypes = new int[pts.length / 2]; for (int i = 0; i < jointTypes.length; i++) { jointTypes[i] = 0; formTypes[i] = 0; dotTypes[i] = 0; } ensureArrays(); calculateLengths();
	}
	public SObject(org.json.JSONObject J) throws Exception {
