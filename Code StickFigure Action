			float v1x = p3[fp[1]][0]-p3[fp[0]][0], v1y = p3[fp[1]][1]-p3[fp[0]][1]; float v2x = p3[fp[2]][0]-p3[fp[1]][0], v2y = p3[fp[2]][1]-p3[fp[1]][1]; face.nz = v1x*v2y - v1y*v2x; fl.add(face);
