		if (hideV == null || showV == null) return;
		hideV.animate().alpha(0f).setDuration(200).withEndAction(new Runnable() {
			@Override public void run() { hideV.setVisibility(View.GONE); showV.setAlpha(0f); showV.setVisibility(View.VISIBLE); showV.animate().alpha(1f).setDuration(200).start(); }
		}).start();
