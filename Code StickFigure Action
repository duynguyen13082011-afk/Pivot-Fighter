			float[] p2_2 = target2.pts.length >= 4 ? target2.getAbsoluteDrawPos(1, 0) : p1_2; 
			float px1 = p1[0] + (p1_2[0] - p1[0]) * fraction;
			float py1 = p1[1] + (p1_2[1] - p1[1]) * fraction; 
			float px2 = p2[0] + (p2_2[0] - p2[0]) * fraction;
			float py2 = p2[1] + (p2_2[1] - p2[1]) * fraction; 
			float cx = (px1 + px2) / 2f;
			float cy = (py1 + py2) / 2f;
