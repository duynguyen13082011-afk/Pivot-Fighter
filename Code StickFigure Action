			for(int i=1; i<face.p.length; i++) path.lineTo(p3[face.p[i]][0], p3[face.p[i]][1]); path.close();
			if(ghost) { faceP.setStyle(Paint.Style.STROKE); c.drawPath(path, faceP); }
			else {
				if(o.isFilled) { 
    faceP.setStyle(Paint.Style.FILL);
    int rc = Color.red(o.fillColor), gc = Color.green(o.fillColor), bc = Color.blue(o.fillColor); 
    float lf = face.nz > 0 ? 1.0f : 0.6f;
