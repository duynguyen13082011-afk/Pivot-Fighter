			SObject head = new SObject(11, 0, 0); head.size3DX = 30 * effectiveScale; head.size3DY = 30 * effectiveScale; head.size3DZ = 30 * effectiveScale; head.rot3DX = obj.rot3DX; head.rot3DY = obj.rot3DY; head.rot3DZ = obj.rot3DZ; head.isFilled = obj.isFilled; head.fillColor = obj.fillColor; head.limbColors[0] = obj.limbColors[0]; head.strokeWidth = paint.getStrokeWidth() / 2; engine3D.draw(c, head, offPtsX[0], offPtsY[0], 1.0f, paint, false, head.rot3DX, head.rot3DY, head.rot3DZ); return;
