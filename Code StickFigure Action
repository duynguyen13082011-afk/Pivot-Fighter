    if(!imagePath.isEmpty() && type >= 10) { try { cachedTex = android.graphics.BitmapFactory.decodeFile(imagePath);
 rot3DX = 0; rot3DY = 0; } catch(Exception e){} }
} 
		if (type == 8) { textContent = J.optString("tc", "Text"); textSize = J.optInt("ts", 50);
} 
		if (type == 9) { sfnDataProject = J.optString("sfn", ""); textSize = J.optInt("ts", 50); loadSfnData(); }
		isNeon = J.optBoolean("in", false); neonRadius = J.optInt("nr", 15); neonColor = J.optInt("nc", limbColors[0]); neonBrightness = J.optInt("nb", 1);
		hasBorder = J.optBoolean("hbd", false); borderColor = J.optInt("bdc", Color.BLACK); borderThick = (float) J.optDouble("bdt", 10.0); borderRound = J.optBoolean("bdr", true); borderGlow = J.optInt("bdg", 0);
		strokeWidth = (float) J.optDouble("sw", 15.0); alpha = J.optInt("alp", 255); attachPointIdx = J.optInt("ap", -1); isFilled = J.optBoolean("ifil", false); fillColor = J.optInt("fc", Color.parseColor("#80000000"));
		rot3DX = (float) J.optDouble("r3x", 0); rot3DY = (float) J.optDouble("r3y", 0); rot3DZ = (float) J.optDouble("r3z", 0); pos3DZ = (float) J.optDouble("p3z", 0);
		size3DX = (float) J.optDouble("s3x", 60); size3DY = (float) J.optDouble("s3y", 60); size3DZ = (float) J.optDouble("s3z", 60);
