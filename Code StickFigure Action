	public void drawRecursive(Canvas c, SObject obj1, SObject obj2, float fraction, Paint p, UIHelper ui, float currentTimeSec, float parentScale, int pass) {
		float selfScale = ui.lerp(obj1.scale, obj2.scale, fraction);
		float effectiveScale = selfScale * parentScale; 
        float sw = ui.lerp(obj1.strokeWidth, obj2.strokeWidth, fraction); p.setStrokeWidth(sw); p.setStyle(Paint.Style.STROKE);
		int alphaVal = (int) ui.lerp(obj1.alpha, obj2.alpha, fraction); if (alphaVal < 0) alphaVal = 0;
		if (alphaVal > 255) alphaVal = 255;
		boolean effFlip = (fraction < 0.5f) ? obj1.flip : obj2.flip;
		if (obj1.isNeon) p.setShadowLayer(obj1.neonRadius, 0, 0, obj1.neonColor); else p.setShadowLayer(0, 0, 0, 0);
		float rootX = ui.lerp(obj1.pts[obj1.rootIdx * 2], obj2.pts[obj2.rootIdx * 2], fraction);
		float rootY = ui.lerp(obj1.pts[obj1.rootIdx * 2 + 1], obj2.pts[obj2.rootIdx * 2 + 1], fraction);
		float[] tPtsX = new float[obj1.pts.length / 2]; float[] tPtsY = new float[obj1.pts.length / 2];
		for(int z=0; z<obj1.pts.length/2; z++) { float rX = ui.lerp(obj1.pts[z*2], obj2.pts[z*2], fraction); float rY = ui.lerp(obj1.pts[z*2+1], obj2.pts[z*2+1], fraction);
			tPtsX[z] = rootX + (rX - rootX) * effectiveScale; tPtsY[z] = rootY + (rY - rootY) * effectiveScale;
		}
		
        boolean has3DChild = false;
        for (SObject child : obj1.children) { if (child.type >= 10) has3DChild = true; }
        boolean deferParent3D = (obj1.type >= 10 && obj1.type <= 16 && has3DChild);
        
        // QUATERNION SLERP 3D: Cứu tinh chống lật (Gimbal Lock)
        float curRotX = obj1.rot3DX, curRotY = obj1.rot3DY, curRotZ = obj1.rot3DZ;
        if (obj2 != null && obj1.type >= 10 && obj1.type <= 16) {
            double cx1=Math.cos(curRotX*0.5), sx1=Math.sin(curRotX*0.5), cy1=Math.cos(curRotY*0.5), sy1=Math.sin(curRotY*0.5), cz1=Math.cos(curRotZ*0.5), sz1=Math.sin(curRotZ*0.5);
            double w1=cx1*cy1*cz1+sx1*sy1*sz1, x1=sx1*cy1*cz1-cx1*sy1*sz1, y1=cx1*sy1*cz1+sx1*cy1*sz1, z1=cx1*cy1*sz1-sx1*sy1*cz1;
            double cx2=Math.cos(obj2.rot3DX*0.5), sx2=Math.sin(obj2.rot3DX*0.5), cy2=Math.cos(obj2.rot3DY*0.5), sy2=Math.sin(obj2.rot3DY*0.5), cz2=Math.cos(obj2.rot3DZ*0.5), sz2=Math.sin(obj2.rot3DZ*0.5);
            double w2=cx2*cy2*cz2+sx2*sy2*sz2, x2=sx2*cy2*cz2-cx2*sy2*sz2, y2=cx2*sy2*cz2+sx2*cy2*sz2, z2=cx2*cy2*sz2-sx2*sy2*cz2;
            double dot=w1*w2+x1*x2+y1*y2+z1*z2;
            if(dot<0){ w2=-w2; x2=-x2; y2=-y2; z2=-z2; dot=-dot; }
            double s0,s1;
            if(1.0-dot>0.0001){ double t=Math.acos(dot), st=Math.sin(t); s0=Math.sin((1.0-fraction)*t)/st; s1=Math.sin(fraction*t)/st; }
            else { s0=1.0-fraction; s1=fraction; }
            double w=s0*w1+s1*w2, x=s0*x1+s1*x2, y=s0*y1+s1*y2, z=s0*z1+s1*z2;
            curRotX=(float)Math.atan2(2*(w*x+y*z), 1-2*(x*x+y*y));
            double sp=2*(w*y-z*x); curRotY=(float)(Math.abs(sp)>=1 ? Math.copySign(Math.PI/2, sp) : Math.asin(sp));
            curRotZ=(float)Math.atan2(2*(w*z+x*y), 1-2*(y*y+z*z));
        }

		if (pass == 0) {
			if (obj1.hasBorder) { Paint pBorderMode = new Paint(p); pBorderMode.setColor(obj1.borderColor); pBorderMode.setStrokeWidth(p.getStrokeWidth() + obj1.borderThick); if (obj1.borderRound) pBorderMode.setStrokeJoin(Paint.Join.ROUND);
				if (obj1.borderGlow > 0) pBorderMode.setShadowLayer(obj1.borderGlow, 0, 0, obj1.borderColor);
				if (obj1.type >= 10 && obj1.type <= 16) { 
                    if (!deferParent3D) {
                        engine3D.draw(c, obj1, rootX, rootY, effectiveScale * 1.15f, pBorderMode, false, curRotX, curRotY, curRotZ);
                    }
				} else { drawObjectPathInternal(c, obj1, tPtsX, tPtsY, effectiveScale, pBorderMode); } }
		}

		if (pass == 1) {
			if (obj1.type >= 10 && obj1.type <= 16) { 
                if (!deferParent3D) {
                    engine3D.draw(c, obj1, rootX, rootY, effectiveScale, p, false, curRotX, curRotY, curRotZ);
                }
            }
			p.setColor(obj1.limbColors[0]); p.setAlpha((Color.alpha(obj1.limbColors[0]) * alphaVal) / 255);
			if (obj1.type == 7 || obj1.type == 8 || obj1.type == 9) { float handleX = tPtsX[1];
				float handleY = tPtsY[1]; float dx = handleX - tPtsX[0]; float dy = handleY - tPtsY[0];
				float dist = (float) Math.hypot(dx, dy); float angle = (float) Math.atan2(dy, dx); float localScale = dist / 100f; c.save();
				c.translate(tPtsX[0], tPtsY[0]); c.rotate((float) Math.toDegrees(angle)); if (effFlip) c.scale(-1, 1);
				if (obj1.type == 9 && obj1.cachedSfnFrames != null && !obj1.cachedSfnFrames.isEmpty()) {
if (obj1.textSize == 50) obj1.textSize = 0; float projFps = getSharedPreferences("StickDataV34", 0).getInt("play_fps", 12); float projSpeed = getSharedPreferences("StickDataV34", 0).getFloat("play_speed", 1.0f); float exactFrame = currentTimeSec * (projFps * projSpeed) - obj1.textSize; if(exactFrame < 0) exactFrame = 0; int count = obj1.cachedSfnFrames.size(); int idx1 = (int) exactFrame % count;
					int idx2 = (idx1 + 1) % count; float subFraction = exactFrame - (int) exactFrame; java.util.List<SObject> subFrame1 = obj1.cachedSfnFrames.get(idx1);
					java.util.List<SObject> subFrame2 = obj1.cachedSfnFrames.get(idx2); c.scale(localScale, localScale); 
                    for (int k = 0; k < subFrame1.size(); k++) { SObject s1 = subFrame1.get(k);
					    SObject s2 = (k < subFrame2.size()) ? subFrame2.get(k) : s1; drawRecursive(c, s1, s2, subFraction, p, ui, currentTimeSec, 1.0f, pass);
					} 
                }
				else if (obj1.type == 7) { Paint alphaP = new Paint(); alphaP.setAlpha(alphaVal);
					try { if (obj1.gifMovie != null && obj1.gifMovie.duration() > 0) { obj1.gifMovie.setTime((int)((currentTimeSec * 1000) % obj1.gifMovie.duration()));
						float w = obj1.gifMovie.width() * localScale; float h = obj1.gifMovie.height() * localScale;
						c.saveLayerAlpha(new android.graphics.RectF(-w / 2, -h / 2, w / 2, h / 2), alphaVal); c.scale(w / obj1.gifMovie.width(), h / obj1.gifMovie.height());
						c.translate(-obj1.gifMovie.width() / 2f, -obj1.gifMovie.height() / 2f); obj1.gifMovie.draw(c, 0, 0); c.restore(); } else if (!obj1.imagePath.isEmpty()) { Bitmap imgBmp = android.graphics.BitmapFactory.decodeFile(obj1.imagePath);
						if (imgBmp != null) { float w = imgBmp.getWidth() * localScale; float h = imgBmp.getHeight() * localScale;
							c.drawBitmap(imgBmp, null, new android.graphics.RectF(-w / 2, -h / 2, w / 2, h / 2), alphaP);
						} } } catch (Exception e) {} 
                } 
				else if (obj1.type == 8) { p.setStyle(Paint.Style.FILL); p.setColor(obj1.limbColors[0]);
					p.setAlpha((Color.alpha(obj1.limbColors[0]) * alphaVal) / 255); if(APP_FONT != null) p.setTypeface(APP_FONT); p.setTextSize(obj1.textSize * effectiveScale * localScale); c.drawText(obj1.textContent, 0, 0, p); 
                } 
                c.restore();
			} else if (obj1.type < 10 || obj1.type == 13) { drawObjectPathInternal(c, obj1, tPtsX, tPtsY, effectiveScale, p);
			}
		}
        
        java.util.List<Integer> behind = new java.util.ArrayList<>();
        java.util.List<Integer> front = new java.util.ArrayList<>();
        final float[] dynX = new float[obj1.children.size()];
        final float[] dynY = new float[obj1.children.size()];
        final float[] dynZ = new float[obj1.children.size()];
        
        if (deferParent3D) {
            float pRx = ui.lerp(obj1.pts[0], obj2.pts[0], fraction);
            float pRy = ui.lerp(obj1.pts[1], obj2.pts[1], fraction);
            float pZ = ui.lerp(obj1.pos3DZ, obj2.pos3DZ, fraction);
            
            for (int i = 0; i < obj1.children.size(); i++) {
                SObject c1 = obj1.children.get(i);
                float[] r3 = engine3D.rotate3D(c1.localOffX, c1.localOffY, c1.localOffZ, curRotX, curRotY, curRotZ);
                dynX[i] = pRx + r3[0];
                dynY[i] = pRy + r3[1];
                dynZ[i] = pZ + r3[2];
                if (dynZ[i] > pZ) behind.add(i);
                else front.add(i);
            }
            java.util.Collections.sort(behind, new java.util.Comparator<Integer>() {
                public int compare(Integer a, Integer b) { return Float.compare(dynZ[b], dynZ[a]); }
            });
            java.util.Collections.sort(front, new java.util.Comparator<Integer>() {
                public int compare(Integer a, Integer b) { return Float.compare(dynZ[b], dynZ[a]); }
            });
        } else {
            for (int i = 0; i < obj1.children.size(); i++) front.add(i);
        }

		for (int i : behind) { 
            SObject c1 = obj1.children.get(i);
            SObject c2 = (obj2 != null && i < obj2.children.size()) ? obj2.children.get(i) : c1;
            int at = c1.attachPointIdx;
            if (at < 0) { 
                if (obj1.type >= 10 && c1.type >= 10) { 
                    float cRx = deferParent3D ? dynX[i] : ui.lerp(c1.pts[0], c2.pts[0], fraction);
                    float cRy = deferParent3D ? dynY[i] : ui.lerp(c1.pts[1], c2.pts[1], fraction); 
                    float pRx = ui.lerp(obj1.pts[0], obj2.pts[0], fraction); 
                    float pRy = ui.lerp(obj1.pts[1], obj2.pts[1], fraction); 
                    c.save();
                    c.translate(rootX + (cRx - pRx) * effectiveScale - cRx, rootY + (cRy - pRy) * effectiveScale - cRy);
                    drawRecursive(c, c1, c2, fraction, p, ui, currentTimeSec, effectiveScale, pass); 
                    c.restore();
                } 
                continue;
            } 
            float pAx = tPtsX[at];
            float pAy = tPtsY[at];
            float cRx = ui.lerp(c1.pts[c1.rootIdx * 2], c2.pts[c2.rootIdx * 2], fraction);
            float cRy = ui.lerp(c1.pts[c1.rootIdx * 2 + 1], c2.pts[c2.rootIdx * 2 + 1], fraction);
