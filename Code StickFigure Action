final class Engine3D {
	class PrimData { float[][] v; int[][] f; }
	PrimData getPrimitive(int t, float sx, float sy, float sz) {
		PrimData d = new PrimData();
		if(t==10){ float w=sx/4,h=sy,depth=sz/4;
			d.v = new float[][]{{-w,-h,-depth},{w,-h,-depth},{w,h,-depth},{-w,h,-depth},{-w,-h,depth},{w,-h,depth},{w,h,depth},{-w,h,depth}};
			d.f = new int[][]{{0,1,2,3},{1,5,6,2},{5,4,7,6},{4,0,3,7},{3,2,6,7},{4,5,1,0}}; return d;
		}
		if(t==11){
			d.v = new float[][]{{-sx,-sy,-sz},{sx,-sy,-sz},{sx,sy,-sz},{-sx,sy,-sz},{-sx,-sy,sz},{sx,-sy,sz},{sx,sy,sz},{-sx,sy,sz}};
			d.f = new int[][]{{0,1,2,3},{1,5,6,2},{5,4,7,6},{4,0,3,7},{3,2,6,7},{4,5,1,0}}; return d;
		}
		if(t==12){
			d.v = new float[][]{{0,-sy,0},{-sx,sy,-sz},{sx,sy,-sz},{sx,sy,sz},{-sx,sy,sz}};
			d.f = new int[][]{{0,1,2},{0,2,3},{0,3,4},{0,4,1},{4,3,2,1}}; return d;
		}
		if(t==14){ // REAL 3D SPHERE (UV Sphere)
			int stacks = 12, slices = 12;
			d.v = new float[(stacks+1)*(slices+1)][3]; int vIdx = 0;
			for(int i=0; i<=stacks; i++) { float phi = (float)(Math.PI * i / stacks);
				for(int j=0; j<=slices; j++) { float theta = (float)(2 * Math.PI * j / slices);
					d.v[vIdx][0] = (float)(Math.sin(phi) * Math.cos(theta)) * sx;
					d.v[vIdx][1] = (float)(Math.cos(phi)) * sy;
					d.v[vIdx][2] = (float)(Math.sin(phi) * Math.sin(theta)) * sz; vIdx++;
				}
			}
			d.f = new int[stacks*slices][4]; int fIdx = 0;
			for(int i=0; i<stacks; i++) { for(int j=0; j<slices; j++) {
					int p1 = i * (slices + 1) + j; int p2 = p1 + 1; int p3 = (i + 1) * (slices + 1) + (j + 1); int p4 = (i + 1) * (slices + 1) + j;
					d.f[fIdx++] = new int[]{p1, p2, p3, p4};
			} } return d;
		}
		if(t==15){ // CYLINDER
			int slices = 12; d.v = new float[slices*2 + 2][3];
			d.v[0] = new float[]{0, -sy, 0}; d.v[1] = new float[]{0, sy, 0};
			for(int i=0; i<slices; i++) { float theta = (float)(2 * Math.PI * i / slices); float cx = (float)Math.cos(theta); float cz = (float)Math.sin(theta);
				d.v[i+2] = new float[]{cx*sx, -sy, cz*sz}; d.v[i+2+slices] = new float[]{cx*sx, sy, cz*sz}; }
			d.f = new int[slices*3][]; int fIdx = 0;
			for(int i=0; i<slices; i++) { int nxt = (i+1)%slices;
				d.f[fIdx++] = new int[]{0, nxt+2, i+2}; d.f[fIdx++] = new int[]{1, i+2+slices, nxt+2+slices};
				d.f[fIdx++] = new int[]{i+2, nxt+2, nxt+2+slices, i+2+slices}; } return d;
		}
		if(t==16){ // CONE
			int slices = 12; d.v = new float[slices + 2][3];
			d.v[0] = new float[]{0, -sy, 0}; d.v[1] = new float[]{0, sy, 0};
			for(int i=0; i<slices; i++) { float theta = (float)(2 * Math.PI * i / slices);
				d.v[i+2] = new float[]{(float)Math.cos(theta)*sx, sy, (float)Math.sin(theta)*sz}; }
			d.f = new int[slices*2][]; int fIdx = 0;
			for(int i=0; i<slices; i++) { int nxt = (i+1)%slices;
				d.f[fIdx++] = new int[]{0, nxt+2, i+2}; d.f[fIdx++] = new int[]{1, i+2, nxt+2}; } return d;
		}
		return null;
	}
	class F implements Comparable<F> { int[] p; float z, nz; public int compareTo(F o){ return Float.compare(o.z, z); } }
	
	// Default fast draw for Animation canvas (local rotation only)
	void draw(Canvas c, SObject o, float rootX, float rootY, float sc, Paint pt, boolean ghost, float rx, float ry, float rz) {
