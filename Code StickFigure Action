	public void movePoint(int index, float newX, float newY, boolean isStretchMode) { ensureArrays(); float oldX = pts[index * 2]; float oldY = pts[index * 2 + 1]; if (!isStretchMode && formTypes[index] == 1) { float dx = newX - oldX; float dy = newY - oldY; translateEntireObject(dx, dy); return; } int parent = parents[index];
