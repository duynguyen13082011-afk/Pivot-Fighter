            float[] src = {0, 0, w, 0, w, h};
            float[] dst = {p3[face.p[0]][0], p3[face.p[0]][1], p3[face.p[1]][0], p3[face.p[1]][1], p3[face.p[2]][0], p3[face.p[2]][1]};
            m.setPolyToPoly(src, 0, dst, 0, 3);
        }
