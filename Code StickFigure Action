	public void styleBtn(View v, int color) {
		v.setBackground(getShape(color, 40, isDarkMode ? 1 : 0, isDarkMode ? Color.parseColor("#333344") : Color.TRANSPARENT));
		if (v instanceof TextView) { ((TextView) v).setTextColor(color == Color.WHITE && isDarkMode ? Color.BLACK : APP_TEXT_COLOR);
			if (color != Color.WHITE && color != Color.TRANSPARENT && color != APP_BTN_BG) ((TextView) v).setTextColor(Color.WHITE); 
			setFont((TextView) v); ((TextView) v).setGravity(Gravity.CENTER);
		}
		if(android.os.Build.VERSION.SDK_INT >= 21 && color == ACCENT_COLOR) v.setElevation(8f);
		v.setOnTouchListener(new android.view.View.OnTouchListener() {
			@Override public boolean onTouch(View view, MotionEvent event) {
				if (event.getAction() == MotionEvent.ACTION_DOWN) view.animate().scaleX(0.92f).scaleY(0.92f).setDuration(150).start();
				else if (event.getAction() == MotionEvent.ACTION_UP || event.getAction() == MotionEvent.ACTION_CANCEL) view.animate().scaleX(1f).scaleY(1f).setDuration(150).start();
				return false; 
			}
		});
	}
	public float lerp(float start, float end, float fraction) { return start + (end - start) * fraction; }
	public float lerpAngle(float start, float end, float fraction) {
		float d = end - start;
		while (d > Math.PI) d -= 2 * Math.PI;
		while (d < -Math.PI) d += 2 * Math.PI;
		return start + d * fraction;
	}
	public void styleDialog(Dialog d) {
