	} else { float pX = pts[parent * 2]; float pY = pts[parent * 2 + 1]; if (!isStretchMode) { double angle = Math.atan2(newY - pY, newX - pX); float fixedLen = lens[index]; newX = pX + (float)(Math.cos(angle) * fixedLen); newY = pY + (float)(Math.sin(angle) * fixedLen); } double angOld = Math.atan2(oldY - pY, oldX - pX); double angNew = Math.atan2(newY - pY, newX - pX); double diffAngle = angNew - angOld; 
		if ((type == 3 || type == 5 || type == 6 || type >= 10) && !isStretchMode) { float pivotX = pts[rootIdx * 2]; float pivotY = pts[rootIdx * 2 + 1]; rotateEntireObject(pivotX, pivotY, pivotX, pivotY, diffAngle); return; } 
		pts[index * 2] = newX; pts[index * 2 + 1] = newY; rotateChildren(index, newX, newY, diffAngle);
		if (parent == rootIdx) { for (SObject child : children) { if (child.attachPointIdx == rootIdx && child.jointTypes[child.rootIdx] == 1) { child.rotateEntireObject(pX, pY, pX, pY, diffAngle); } } } } }
