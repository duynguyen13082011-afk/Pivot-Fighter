            try { 
                java.io.InputStream is = getContentResolver().openInputStream(uri); 
                java.io.BufferedReader br = new java.io.BufferedReader(new java.io.InputStreamReader(is)); 
                StringBuilder sb = new StringBuilder(); String line; 
                while ((line = br.readLine()) != null) sb.append(line).append("\n"); 
                br.close(); is.close(); 
                String xmlContent = sb.toString(); 
                if (xmlContent.trim().startsWith("{") || xmlContent.trim().startsWith("[")) {
                    final String fData = xmlContent;
                    runOnUiThread(new Runnable() { @Override public void run() { 
                        String name = "Imported_SFN_" + System.currentTimeMillis();
                        if (currentTab[0] == 0) { animNames.add(name); animData.add(fData); } 
                        else if (currentTab[0] == 1) { customNames.add(name); customData.add(fData); } 
                        else if (currentTab[0] == 2) { sfnNames.add(name); sfnData.add(fData); } 
                        else { custom3dNames.add(name); custom3dData.add(fData); } 
                        saveData.run(); 
                        SketchwareUtil.showMessage(getApplicationContext(), tLang.get("IMPORT_SFN")); 
                        recreate(); 
                    } });
                    return;
                }
                String projectName = "SFN_Project";
                int projectBg = Color.WHITE; 
                java.util.List<java.util.List<SObject>> importedFrames = new java.util.ArrayList<>(); 
                org.xmlpull.v1.XmlPullParserFactory factory = org.xmlpull.v1.XmlPullParserFactory.newInstance(); 
                factory.setNamespaceAware(true);
                org.xmlpull.v1.XmlPullParser parser = factory.newPullParser(); 
                parser.setInput(new java.io.StringReader(xmlContent)); 
                int eventType = parser.getEventType(); 
                java.util.List<SObject> currentFrameSObjects = null;
                while (eventType != org.xmlpull.v1.XmlPullParser.END_DOCUMENT) { 
                    String tagName = parser.getName(); 
                    if (eventType == org.xmlpull.v1.XmlPullParser.START_TAG) { 
                        if ("Project".equalsIgnoreCase(tagName)) { 
                            String n = parser.getAttributeValue(null, "Name");
                            if (n != null) projectName = n; 
                            String bg = parser.getAttributeValue(null, "Background");
                            if (bg != null) try { projectBg = Integer.parseInt(bg); } catch (Exception e) {} 
                        } else if ("Frame".equalsIgnoreCase(tagName)) { 
                            currentFrameSObjects = new java.util.ArrayList<>();
                        } else if ("SObject".equalsIgnoreCase(tagName)) { 
                            if (currentFrameSObjects != null) { 
                                int t = 2; try { t = Integer.parseInt(parser.getAttributeValue(null, "type")); } catch(Exception e){}
                                SObject obj = new SObject(t, 0, 0);
                                try { obj.limbColors[0] = Integer.parseInt(parser.getAttributeValue(null, "color")); } catch(Exception e){}
                                try { obj.strokeWidth = Float.parseFloat(parser.getAttributeValue(null, "thick")); } catch(Exception e){}
                                try { obj.scale = Float.parseFloat(parser.getAttributeValue(null, "scale")); } catch (Exception e) {} 
                                try { obj.rootIdx = Integer.parseInt(parser.getAttributeValue(null, "rootIdx")); } catch (Exception e) {} 
                                try { obj.attachPointIdx = Integer.parseInt(parser.getAttributeValue(null, "attachPointIdx")); } catch (Exception e) {} 
                                try { obj.alpha = Integer.parseInt(parser.getAttributeValue(null, "alpha")); } catch (Exception e) {} 
                                String ptsStr = parser.getAttributeValue(null, "pts"); 
                                if(ptsStr != null) {
                                    String[] ptsArr = ptsStr.split(","); 
                                    obj.pts = new float[ptsArr.length];
                                    for (int i = 0; i < ptsArr.length; i++) {
                                        try { obj.pts[i] = Float.parseFloat(ptsArr[i]); } catch(Exception e){}
                                    }
                                }
                                int savedColor = obj.limbColors[0];
                                obj.limbColors = new int[obj.pts.length / 2];
                                for (int k = 0; k < obj.limbColors.length; k++) obj.limbColors[k] = savedColor;
                                obj.color = savedColor;
                                obj.initParents(); obj.calculateLengths(); obj.ensureArrays(); 
                                currentFrameSObjects.add(obj);
                            } 
                        } 
                    } else if (eventType == org.xmlpull.v1.XmlPullParser.END_TAG) { 
                        if ("Frame".equalsIgnoreCase(tagName)) { 
                            if (currentFrameSObjects != null) importedFrames.add(currentFrameSObjects);
                        } 
                    } 
                    eventType = parser.next(); 
                } 
                if (!importedFrames.isEmpty()) { 
                    org.json.JSONObject projObj = new org.json.JSONObject(); 
                    org.json.JSONArray framesArr = new org.json.JSONArray();
                    org.json.JSONArray bgsArr = new org.json.JSONArray(); 
                    for (java.util.List<SObject> frame: importedFrames) { 
                        org.json.JSONArray objArr = new org.json.JSONArray(); 
                        for (SObject obj: frame) objArr.put(obj.toJson());
                        framesArr.put(objArr); bgsArr.put(projectBg); 
                    } 
                    projObj.put("frames", framesArr); projObj.put("bgs", bgsArr); 
                    final String fName = projectName; final String fData = projObj.toString();
                    runOnUiThread(new Runnable() { @Override public void run() { 
                        if (currentTab[0] == 0) { animNames.add(fName); animData.add(fData); } 
                        else if (currentTab[0] == 1) { customNames.add(fName); customData.add(fData); } 
                        else if (currentTab[0] == 2) { sfnNames.add(fName); sfnData.add(fData); } 
                        else { custom3dNames.add(fName); custom3dData.add(fData); } 
                        saveData.run(); 
                        SketchwareUtil.showMessage(getApplicationContext(), tLang.get("IMPORT_SFN")); 
                        recreate(); 
                    } });
                } 
            } catch (Exception e) {
                runOnUiThread(new Runnable() { @Override public void run() { 
                    SketchwareUtil.showMessage(getApplicationContext(), "Lỗi Import SFN: " + e.getMessage()); 
                } });
            } 
        } }).start(); 
    } }
