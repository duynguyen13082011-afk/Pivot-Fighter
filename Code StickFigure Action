				gp.setColor(Color.RED); c.drawText(txt, px1[0]*camZoom, px1[1]*camZoom + 15, gp); c.drawText(txtR, px2[0]*camZoom, px2[1]*camZoom + 15, gp);
				gp.setColor(Color.GREEN); c.drawText(txtU, py1[0]*camZoom, py1[1]*camZoom + 15, gp); c.drawText(txtD, py2[0]*camZoom, py2[1]*camZoom + 15, gp);
				gp.setColor(Color.BLUE); c.drawText(txtU, pz1[0]*camZoom, pz1[1]*camZoom + 15, gp); c.drawText(txtD, pz2[0]*camZoom, pz2[1]*camZoom + 15, gp);
			} else if (transformMode == 1) {
				gp.setStyle(Paint.Style.STROKE); gp.setStrokeWidth(8);
				gp.setColor(Color.GREEN); c.drawOval(new android.graphics.RectF(scx - alen, scy - alen/3, scx + alen, scy + alen/3), gp);
				gp.setColor(Color.RED); c.drawOval(new android.graphics.RectF(scx - alen/3, scy - alen, scx + alen/3, scy + alen), gp);
			}
		}
		c.restore();
	}
	@Override public boolean onTouchEvent(MotionEvent ev) {
		pointerCount = ev.getPointerCount();
		float x = ev.getX(); float y = ev.getY();
		if (ev.getAction() == MotionEvent.ACTION_DOWN || (ev.getAction() & MotionEvent.ACTION_MASK) == MotionEvent.ACTION_POINTER_DOWN) {
			startX = x; startY = y; startCamX = camPanX; startCamY = camPanY; startRotX = camRotX; startRotY = camRotY; activeGizmo = 0;
			if (pointerCount >= 2) {
				startDist = (float) Math.hypot(ev.getX(0) - ev.getX(1), ev.getY(0) - ev.getY(1)); startCamZoom = camZoom;
			} else if (pointerCount == 1) {
				float tapX = x - camPanX; float tapY = y - camPanY;
				if (selectedObj != null) {
					float[] r2c = engine3D.rotate3D(selectedObj.pts[0], selectedObj.pts[1], selectedObj.pos3DZ, camRotX, camRotY, 0);
					float scx = r2c[0]*camZoom; float scy = r2c[1]*camZoom; float alen = 180;
					if (transformMode == 0 || transformMode == 2) {
						float[] px1 = engine3D.rotate3D(selectedObj.pts[0] + alen/camZoom, selectedObj.pts[1], selectedObj.pos3DZ, camRotX, camRotY, 0); float[] px2 = engine3D.rotate3D(selectedObj.pts[0] - alen/camZoom, selectedObj.pts[1], selectedObj.pos3DZ, camRotX, camRotY, 0);
						float[] py1 = engine3D.rotate3D(selectedObj.pts[0], selectedObj.pts[1] + alen/camZoom, selectedObj.pos3DZ, camRotX, camRotY, 0); float[] py2 = engine3D.rotate3D(selectedObj.pts[0], selectedObj.pts[1] - alen/camZoom, selectedObj.pos3DZ, camRotX, camRotY, 0);
						float[] pz1 = engine3D.rotate3D(selectedObj.pts[0], selectedObj.pts[1], selectedObj.pos3DZ + alen/camZoom, camRotX, camRotY, 0); float[] pz2 = engine3D.rotate3D(selectedObj.pts[0], selectedObj.pts[1], selectedObj.pos3DZ - alen/camZoom, camRotX, camRotY, 0);
						if (Math.hypot(tapX - px1[0]*camZoom, tapY - px1[1]*camZoom) < 60) activeGizmo = 1;
						else if (Math.hypot(tapX - px2[0]*camZoom, tapY - px2[1]*camZoom) < 60) activeGizmo = 2;
						else if (Math.hypot(tapX - py1[0]*camZoom, tapY - py1[1]*camZoom) < 60) activeGizmo = 3;
						else if (Math.hypot(tapX - py2[0]*camZoom, tapY - py2[1]*camZoom) < 60) activeGizmo = 4;
						else if (Math.hypot(tapX - pz1[0]*camZoom, tapY - pz1[1]*camZoom) < 60) activeGizmo = 5;
						else if (Math.hypot(tapX - pz2[0]*camZoom, tapY - pz2[1]*camZoom) < 60) activeGizmo = 6;
					} else if (transformMode == 1) {
						float distY = Math.abs((float)Math.pow((tapX - scx)/alen, 2) + (float)Math.pow((tapY - scy)/(alen/3), 2) - 1);
						float distX = Math.abs((float)Math.pow((tapX - scx)/(alen/3), 2) + (float)Math.pow((tapY - scy)/alen, 2) - 1);
						if (distY < 0.3f) activeGizmo = 7; else if (distX < 0.3f) activeGizmo = 8;
					}
				}
				if (activeGizmo == 0) {
					SObject touched = null;
					for (int i = sceneObjects.size() - 1; i >= 0; i--) {
						SObject o = sceneObjects.get(i);
						Engine3D.PrimData d = engine3D.getPrimitive(o.type, o.size3DX, o.size3DY, o.size3DZ);
						if(d == null) continue;
						float minX=10000, minY=10000, maxX=-10000, maxY=-10000;
						for(int k=0; k<d.v.length; k++) {
							float[] r1 = engine3D.rotate3D(d.v[k][0], d.v[k][1], d.v[k][2], o.rot3DX, o.rot3DY, o.rot3DZ);
							float wx = r1[0]*o.scale + o.pts[0]; float wy = r1[1]*o.scale + o.pts[1]; float wz = r1[2]*o.scale + o.pos3DZ;
							float[] r2 = engine3D.rotate3D(wx, wy, wz, camRotX, camRotY, 0);
							float px = r2[0]*camZoom; float py = r2[1]*camZoom;
							if(px < minX) minX = px; if(py < minY) minY = py; if(px > maxX) maxX = px; if(py > maxY) maxY = py;
						}
						if (tapX >= minX && tapX <= maxX && tapY >= minY && tapY <= maxY) { touched = o; break; }
					}
					if (touched != null) { 
    if (selectedObj == touched) selectedObj = null; else selectedObj = touched;
} else { selectedObj = null; } 
if (selectedObj != null) btn3DImage.setVisibility(View.VISIBLE);
else btn3DImage.setVisibility(View.GONE);
				}
			}
		} else if (ev.getAction() == MotionEvent.ACTION_MOVE) {
			float dx = x - startX; float dy = y - startY;
			if (pointerCount == 1) { 
				if (activeGizmo != 0 && selectedObj != null) {
					float sMove = 2.0f / camZoom; float sScale = 0.5f; float sRot = 0.02f;
					if (transformMode == 0) {
						if (activeGizmo == 1) selectedObj.pts[0] += dx * sMove; else if (activeGizmo == 2) selectedObj.pts[0] += dx * sMove;
						else if (activeGizmo == 3) selectedObj.pts[1] += dy * sMove; else if (activeGizmo == 4) selectedObj.pts[1] += dy * sMove;
						else if (activeGizmo == 5 || activeGizmo == 6) selectedObj.pos3DZ -= (dx+dy) * sMove * 0.5f;
					} else if (transformMode == 2) {
						if (activeGizmo == 1) selectedObj.size3DX += dx * sScale; else if (activeGizmo == 2) selectedObj.size3DX -= dx * sScale;
						else if (activeGizmo == 3) selectedObj.size3DY += dy * sScale; else if (activeGizmo == 4) selectedObj.size3DY -= dy * sScale;
						else if (activeGizmo == 5 || activeGizmo == 6) selectedObj.size3DZ -= (dx+dy) * sScale;
						if(selectedObj.size3DX < 0) selectedObj.size3DX = 0;
if(selectedObj.size3DY < 0) selectedObj.size3DY = 0; if(selectedObj.size3DZ < 0) selectedObj.size3DZ = 0;
					} else if (transformMode == 1) {
						if (activeGizmo == 7) selectedObj.rot3DY += dx * sRot;
						else if (activeGizmo == 8) selectedObj.rot3DX += dy * sRot;
					}
					startX = x; startY = y;
				} else {
					camRotX = startRotX - dy * 0.01f; camRotY = startRotY + dx * 0.01f;
				}
			} else if (pointerCount >= 2) { 
				camPanX = startCamX + dx; camPanY = startCamY + dy;
				float currentDist = (float) Math.hypot(ev.getX(0) - ev.getX(1), ev.getY(0) - ev.getY(1));
				if (startDist > 10f) camZoom = startCamZoom * (currentDist / startDist);
			}
			invalidate();
		}
		return true;
	}
};

