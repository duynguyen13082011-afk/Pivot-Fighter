				float[] px1 = engine3D.rotate3D(selectedObj.pts[0] + alen/camZoom, selectedObj.pts[1], selectedObj.pos3DZ, camRotX, camRotY, 0); float[] px2 = engine3D.rotate3D(selectedObj.pts[0] - alen/camZoom, selectedObj.pts[1], selectedObj.pos3DZ, camRotX, camRotY, 0);
