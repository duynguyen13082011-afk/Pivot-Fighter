		if ((type >= 7 && type <= 9) && pts.length == 2) pts = new float[]{pts[0], pts[1], pts[0] + 100, pts[1]};
		else if ((type >= 10 && type <= 16) && pts.length > 2) pts = new float[]{pts[0], pts[1]};
		org.json.JSONArray cArr = J.optJSONArray("lc"); limbColors = new int[pts.length / 2]; if (cArr != null) for (int i = 0; i < Math.min(cArr.length(), limbColors.length); i++) limbColors[i] = cArr.getInt(i); else for (int i = 0; i < limbColors.length; i++) limbColors[i] = Color.BLACK;
		rootIdx = J.optInt("ri", ((type == 0 || type == 13) ? 2 : (type == 4 ? 1 : 0))); color = limbColors[0];
		org.json.JSONArray pArr = J.optJSONArray("pr"); if (pArr != null) { parents = new int[pts.length / 2]; for (int i = 0; i < Math.min(pArr.length(), parents.length); i++) parents[i] = pArr.getInt(i); } else initParents();
		org.json.JSONArray jArr = J.optJSONArray("jt"); jointTypes = new int[pts.length / 2]; if (jArr != null) for (int i = 0; i < Math.min(jArr.length(), jointTypes.length); i++) jointTypes[i] = jArr.getInt(i);
		org.json.JSONArray fArr = J.optJSONArray("ft"); formTypes = new int[pts.length / 2]; if (fArr != null) for (int i = 0; i < Math.min(fArr.length(), formTypes.length); i++) formTypes[i] = fArr.getInt(i);
		org.json.JSONArray dtArr = J.optJSONArray("dt"); dotTypes = new int[pts.length / 2]; if (dtArr != null) for (int i = 0; i < Math.min(dtArr.length(), dotTypes.length); i++) dotTypes[i] = dtArr.getInt(i);
		org.json.JSONArray lidArr = J.optJSONArray("lid"); if (lidArr != null) { linkedIds = new String[lidArr.length()]; for(int i=0; i<lidArr.length(); i++) linkedIds[i] = lidArr.getString(i); }
		org.json.JSONArray lptArr = J.optJSONArray("lpt"); if (lptArr != null) { linkedPts = new int[lptArr.length()]; for(int i=0; i<lptArr.length(); i++) linkedPts[i] = lptArr.getInt(i); }
		if (type == 7 || (type >= 10 && type <= 16)) { 
    imagePath = J.optString("ip", ""); 
    alpha = J.optInt("al", 255); 
