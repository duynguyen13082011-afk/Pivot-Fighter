	public android.graphics.drawable.Drawable getShape(int color, int radius, int borderW, int borderC) {
		android.graphics.drawable.GradientDrawable gd = new android.graphics.drawable.GradientDrawable();
		gd.setColor(color); gd.setCornerRadius(radius);
		if (borderW > 0) gd.setStroke(borderW, borderC); return gd;
	}
	public android.graphics.drawable.Drawable getGradient(int c1, int c2, int radius) {
		android.graphics.drawable.GradientDrawable gd = new android.graphics.drawable.GradientDrawable(android.graphics.drawable.GradientDrawable.Orientation.TL_BR, new int[]{c1, c2});
		gd.setCornerRadius(radius); return gd;
	}
	public void setFont(TextView v) { if (APP_FONT != null) v.setTypeface(APP_FONT); }
	public void playSound(View v) { 
		if (v != null) {
			try { int resId = v.getContext().getResources().getIdentifier("button_click", "raw", v.getContext().getPackageName());
				if (resId != 0) { android.media.MediaPlayer mp = android.media.MediaPlayer.create(v.getContext(), resId); mp.start();
					mp.setOnCompletionListener(new android.media.MediaPlayer.OnCompletionListener() { public void onCompletion(android.media.MediaPlayer m) { m.release(); } });
				} else { v.playSoundEffect(android.view.SoundEffectConstants.CLICK); }
			} catch (Exception e) { v.playSoundEffect(android.view.SoundEffectConstants.CLICK); }
		}
