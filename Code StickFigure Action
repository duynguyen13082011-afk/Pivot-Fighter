		float cx = 0, cy = 0; for(float[] pt : pts) { cx += pt[0]; cy += pt[1]; } cx /= pts.size(); final float fcy = cy, fcx = cx;
		java.util.Collections.sort(pts, new java.util.Comparator<float[]>() { public int compare(float[] a, float[] b) { return Double.compare(Math.atan2(a[1]-fcy, a[0]-fcx), Math.atan2(b[1]-fcy, b[0]-fcx)); } });
		Path path = new Path(); path.moveTo(pts.get(0)[0], pts.get(0)[1]); for(int i=1; i<pts.size(); i++) path.lineTo(pts.get(i)[0], pts.get(i)[1]); path.close(); p.setColor(obj1.fillColor); p.setStyle(Paint.Style.FILL); c.drawPath(path, p);
	}
	private void collect(SObject o1, SObject o2, float f, java.util.List<float[]> pts, java.util.HashSet<String> vis, java.util.List<SObject> allObjs) {
		if(o1 == null || vis.contains(o1.uuid)) return; vis.add(o1.uuid);
		SObject target2 = (o2 != null) ? o2 : o1; o1.ensureArrays(); target2.ensureArrays();
		for(int i=0; i<o1.pts.length/2; i++) { float[] p1 = o1.getAbsoluteDrawPos(i, 0); float[] p2 = target2.getAbsoluteDrawPos(i, 0);
		pts.add(new float[]{ p1[0] + (p2[0]-p1[0])*f, p1[1] + (p2[1]-p1[1])*f }); if(o1.linkedObjs != null && o1.linkedObjs[i] != null) { SObject l2 = (target2.linkedObjs != null && target2.linkedObjs.length > i) ?
		target2.linkedObjs[i] : null; collect(o1.linkedObjs[i], l2, f, pts, vis, allObjs); } } for(int i=0; i<o1.children.size(); i++) { SObject c1 = o1.children.get(i);
		SObject c2 = (target2.children.size() > i) ? target2.children.get(i) : c1; collect(c1, c2, f, pts, vis, allObjs);
		}
        if (o1.parentObj != null) {
            SObject p2 = (target2.parentObj != null) ? target2.parentObj : o1.parentObj;
            collect(o1.parentObj, p2, f, pts, vis, allObjs);
        }
        if (allObjs != null) {
            for (SObject root : allObjs) checkLinksTo(root, o1, f, pts, vis, allObjs);
        }
	}
    private void checkLinksTo(SObject current, SObject target, float f, java.util.List<float[]> pts, java.util.HashSet<String> vis, java.util.List<SObject> allObjs) {
