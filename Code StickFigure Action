					float[] r1 = engine3D.rotate3D(d.v[i][0], d.v[i][1], d.v[i][2], selectedObj.rot3DX, selectedObj.rot3DY, selectedObj.rot3DZ);
					float wx = r1[0]*selectedObj.scale + selectedObj.pts[0]; float wy = r1[1]*selectedObj.scale + selectedObj.pts[1]; float wz = r1[2]*selectedObj.scale + selectedObj.pos3DZ;
					float[] r2 = engine3D.rotate3D(wx, wy, wz, camRotX, camRotY, 0); p3[i][0] = r2[0]*camZoom; p3[i][1] = r2[1]*camZoom;
				}
				Paint sp = new Paint(); sp.setStyle(Paint.Style.STROKE); sp.setColor(Color.YELLOW); sp.setStrokeWidth(8); sp.setShadowLayer(15, 0, 0, Color.YELLOW);
